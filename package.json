{
  "name": "clvnkhr.github.io",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "typst": "0.14.2"
  },
  "scripts": {
    "build": "bun run src/build/index.ts",
    "build:watch": "bun --watch src/build/index.ts",
    "serve": "bunx serve dist -l 3000",
    "dev": "bun run build:watch & bun run serve",
    "clean": "rm -rf dist",
    "test": "bun test --path-ignore-patterns='lib/**' --path-ignore-patterns='node_modules/**' test/",
    "test:watch": "bun test --watch --path-ignore-patterns='lib/**' --path-ignore-patterns='node_modules/**' test/"
  },
  "dependencies": {
    "effect": "3.21.1",
    "@effect/platform": "0.95.0",
    "@effect/platform-bun": "0.88.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "pagefind": "^1.0.0"
  },
  "devDependencies": {
    "@catppuccin/tailwindcss": "^1.0.0",
    "@seangenabe/catppuccin-tailwindcss-v4": "^1.0.2",
    "@tailwindcss/cli": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bun": "1.2.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.1.18"
  }
}
